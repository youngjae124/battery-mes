# Battery MES 환경변수 설정
# EC2 배포 시: cp .env.example .env 후 값을 채우세요

# PostgreSQL
DB_NAME=battery_mes_qms
DB_USERNAME=battery_user
DB_PASSWORD=여기에_강력한_비밀번호_입력

# JWT 시크릿 (64자 이상 랜덤 문자열 권장)
JWT_SECRET=여기에_랜덤_문자열_입력_최소_64자이상

# Google Gemini API (AI 기능 사용 시 필수, 무료 티어 있음)
# aistudio.google.com 에서 발급
GEMINI_API_KEY=여기에_실제_키_입력

# 로컬에서만 필요 (EC2에서는 이 줄 삭제하거나 주석처리)
# POSTGRES_PORT=5433
